# Supabase Configuration
# Získejte tyto hodnoty z vašeho Supabase projektu:
# Settings > API > Project URL a anon public key

# URL vašeho Supabase projektu
EXPO_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co

# Anon/public API klíč (bezpečný pro klientské aplikace)
# Všechny operace jsou chráněny Row Level Security (RLS) politikami
EXPO_PUBLIC_SUPABASE_KEY=your-anon-public-api-key-here

# Poznámky:
# - Prefix EXPO_PUBLIC_ znamená, že proměnná bude k dispozici v klientské aplikaci
# - NIKDY NEPOUŽÍVEJTE service_role klíč v klientské aplikaci!
# - .env soubor je v .gitignore a nebude commitován do repozitáře
