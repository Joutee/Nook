{
  "permissions": {
    "allow": [
      "Edit(*.ts)",
      "Edit(*.tsx)",
      "Edit(*.js)",
      "Edit(*.jsx)",
      "Edit(*.json)",
      "Edit(*.css)",
      "Edit(*.sql)",
      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(npm run *)",
      "Bash(pnpm run *)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)"
    ],
    "deny": [
      "Bash(npm install *)",
      "Bash(yarn add *)",
      "Bash (pip install *)",
      "Bash(uninstall *)",
      "Bash(rm *)",
      "Bash(rm -rf *)",
      "Bash(rmdir *)",
      "Bash(curl *)",
      "Bash(wget *)",
      "Bash(ssh *)",
      "Bash(scp *)",
      "Read(.env)",
      "Read(*.env.*)",
      "Read(*.key)",
      "Read(*.pem)",
      "Read(*.crt)",
      "Read(*.cert)",
      "Read(**/secrets/*)"
    ]
  },
  "enabledMcpjsonServers": ["supabase"]
}
